# 异动检测阈值
thresholds:
  price_change_pct: 5.0       # 日涨跌幅超过此值触发
  volume_spike_ratio: 2.5     # 成交量超过20日均量的倍数
  consecutive_days: 3          # 连续同方向天数
  consecutive_change_pct: 3.0  # 连续变化累计百分比
  lookback_days: 30            # 历史数据窗口

# 投资假设追踪
hypotheses:
  - id: "h1"
    text: "银行板块将受益于降息周期，估值修复"
    related_symbols: ["000001", "601398"]
    active: true
  - id: "h2"
    text: "消费复苏预期下白酒板块将迎来戴维斯双击"
    related_symbols: ["600519", "000858"]
    active: true
  - id: "h3"
    text: "AI算力需求持续增长，半导体产业链受益"
    related_symbols: ["NVDA", "AVGO", "688041"]
    active: true

# LLM提供商设置
# provider: "claude" / "ollama" / "openrouter" / "nvidia"
llm:
  provider: "openrouter"

# Claude API设置（provider=claude时生效）
claude:
  model: "claude-sonnet-4-20250514"
  max_tokens: 1024
  # API key从环境变量ANTHROPIC_API_KEY读取

# Ollama设置（provider=ollama时生效）
ollama:
  model: "gemma4:31b-cloud"
  base_url: "http://localhost:11434"
  # base_url: "http://your-server:11434"  # 远程服务器

# OpenRouter设置（provider=openrouter时生效）
# 注册: https://openrouter.ai  获取API Key
# 模型列表: https://openrouter.ai/models
# API key从环境变量OPENROUTER_API_KEY读取
openrouter:
  model: "openrouter/free"
  # 其他推荐模型:
  #   "google/gemini-2.0-flash-exp:free"     免费
  #   "deepseek/deepseek-chat"               便宜
  #   "anthropic/claude-sonnet-4"             高质量

# NVIDIA build.nvidia.com设置（provider=nvidia时生效）
# 注册: https://build.nvidia.com  获取API Key
# 模型列表: https://build.nvidia.com/explore/discover
# API key从环境变量NVIDIA_API_KEY读取
nvidia:
  model: "deepseek-ai/deepseek-v4-flash"
  # 其他推荐模型:
  #   "meta/llama-3.1-405b-instruct"         最强开源
  #   "nvidia/nemotron-4-340b-instruct"       NVIDIA自研
  #   "deepseek/deepseek-r1"                  推理模型

# TqSdk天勤量化设置（期货数据源）
# 注册: https://www.shinnytech.com/tianqin  获取账号密码
tqsdk:
  username: ""  # TODO: 填写天勤账号
  password: ""  # TODO: 填写天勤密码

# 输出设置
output:
  dir: "output"
  keep_days: 30
